FROM node:20

# Install dependencies including build tools and locales
RUN apt-get update && apt-get install -y \
    git \
    build-essential \
    python3 \
    locales \
    && sed -i -e 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen \
    && locale-gen \
    && update-locale LANG=en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

# Set locale environment variables
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV LC_CTYPE=en_US.UTF-8

# Create pocketdev user early
RUN useradd -m -s /bin/bash pocketdev && \
    mkdir -p /home/pocketdev/.npm-global && \
    chown -R pocketdev:pocketdev /home/pocketdev

# Configure npm to use pocketdev's global directory
ENV NPM_CONFIG_PREFIX=/home/pocketdev/.npm-global
ENV PATH=$NPM_CONFIG_PREFIX/bin:$PATH

# Switch to pocketdev user to install Claude
USER pocketdev
RUN npm install -g @anthropic-ai/claude-code

# Create and switch to app directory
WORKDIR /app

# Install node-pty with rebuild as pocketdev
RUN npm init -y && npm install ws node-pty
RUN npm rebuild node-pty

# Switch back to root for file creation
USER root

# Simple PTY server
RUN echo 'const { WebSocketServer } = require("ws"); \
const pty = require("node-pty"); \
const wss = new WebSocketServer({ port: 8080 }); \
wss.on("connection", (ws) => { \
  console.log("Client connected"); \
  const shell = pty.spawn("bash", [], { \
    name: "xterm-256color", \
    cols: 80, \
    rows: 24, \
    cwd: process.cwd(), \
    env: process.env \
  }); \
  shell.onData(d => ws.send(d)); \
  ws.on("message", d => shell.write(d.toString())); \
  ws.on("close", () => { \
    console.log("Client disconnected"); \
    shell.kill(); \
  }); \
}); \
console.log("WebSocket server listening on port 8080");' > server.js

# Set ownership of app directory to pocketdev user
RUN chown -R pocketdev:pocketdev /app

# Switch to pocketdev user
USER pocketdev

EXPOSE 8080
CMD ["node", "server.js"]