# PocketDev AI Base Image with AI Tools and Development Utilities
FROM ubuntu:22.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install comprehensive system dependencies for AI development environment
RUN apt-get update && apt-get install -y \
    curl \
    git \
    python3 \
    python3-pip \
    build-essential \
    jq \
    netstat-nat \
    net-tools \
    iproute2 \
    strace \
    procps \
    psmisc \
    lsof \
    locales \
    ca-certificates \
    && sed -i -e 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen \
    && locale-gen \
    && update-locale LANG=en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

# Set locale environment variables
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV LC_CTYPE=en_US.UTF-8

# Install Node.js 22 (required for npm packages)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && \
    apt-get install -y gh && \
    rm -rf /var/lib/apt/lists/*

# Create pocketdev user and set up npm global directory
RUN useradd -m -s /bin/bash pocketdev && \
    mkdir -p /home/pocketdev/.npm-global && \
    chown -R pocketdev:pocketdev /home/pocketdev

# Configure npm to use pocketdev's global directory
ENV NPM_CONFIG_PREFIX=/home/pocketdev/.npm-global
ENV PATH=$NPM_CONFIG_PREFIX/bin:$PATH

# TODO: Consolidate user switching and installations to avoid multiple USER commands
# Switch to pocketdev user for all subsequent installations
USER pocketdev
WORKDIR /home/pocketdev

# Install AI CLI tools as pocketdev user
RUN npm install -g @anthropic-ai/claude-code

# Install other AI agent CLIs as pocketdev user
RUN npm install -g \
    @openai/codex \
    @google/gemini-cli \
    ccusage

# Install development tools as pocketdev user
RUN npm install -g \
    typescript \
    @types/node \
    nodemon

# Install Python-based AI coding agents and SDKs as pocketdev user
RUN pip3 install --user \
    aider-chat \
    openai \
    google-generativeai \
    anthropic \
    tiktoken

# Add Python user bin to PATH
ENV PATH=/home/pocketdev/.local/bin:$PATH

# TODO: Install systems as the correct user - who should that be?
# Switch back to root for remaining system installations
USER root

# Install Docker CLI (for container management from within tasks)
RUN curl -fsSL https://get.docker.com | sh - && \
    rm -rf /var/lib/apt/lists/* && \
    usermod -aG docker pocketdev

# Install additional development tools that AI coders often need
RUN apt-get update && apt-get install -y \
    vim \
    nano \
    htop \
    tree \
    wget \
    zip \
    unzip \
    postgresql-client \
    mysql-client \
    redis-tools \
    && rm -rf /var/lib/apt/lists/*

# Switch to pocketdev user to install Node.js development tools
USER pocketdev

# Install useful Node.js development tools as pocketdev user
RUN npm install -g \
    yarn \
    pnpm \
    jest \
    mocha \
    eslint \
    prettier

# Switch back to root for final configurations
USER root

# TODO: remove the global git config, this should be handled in a better way
# Configure git to trust all directories (fixes ownership issues)
RUN git config --global --add safe.directory '*'

# Environment variables for AI services (to be set at runtime)
ENV ANTHROPIC_API_KEY=""
ENV OPENAI_API_KEY=""
ENV GOOGLE_API_KEY=""
ENV GEMINI_API_KEY=""
ENV GITHUB_TOKEN=""

# TODO: We should install these as a non root user
# Create workspace directories
RUN mkdir -p /workspace /projects && \
    chmod 755 /workspace /projects && \
    chown pocketdev:pocketdev /workspace /projects

# Aider configuration directory
RUN mkdir -p /home/pocketdev/.aider && \
    chown -R pocketdev:pocketdev /home/pocketdev/.aider

# Labels for tracking
LABEL maintainer="Pocketdev Team"
LABEL description="Base image for Pocketdev services. Includes development tools and configurations for AI coding agents."
LABEL version="1.0"

# TODO: remove this, this is a workaround for the current issue with git ownership
# Configure git safe directories for pocketdev user
USER pocketdev
RUN git config --global --add safe.directory '*'

# TODO: check the actual working directrory we should be in
# Default to non-root user (services can override with USER root if needed)
WORKDIR /workspace