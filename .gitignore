# .gitignore for simple directory

# Data directories
data/
projects/
backups/
data-snapshot/
.archived/

# Node modules
node_modules/

# Environment files
.env
.env.local

# System files
.DS_Store
*.log
*.bak
*.backup
*.tmp
*~

# Session data
.tmux-*
*.jsonl

# Vite cache
.vite/
*/.vite/

*.db
*.sqlite

# IDE files
.idea/
.vscode/

# Test results
e2e/test-results/
playwright-report/
test-results/

# Test files
test-deploy/
test-production-local.sh
docker-compose.test-production.yml
nginx.test.conf
.env.test-production
*.png
test_*.js
console_check.js
