FROM node:20-slim

# Install Docker CLI, git, and build dependencies
RUN apt-get update && apt-get install -y \
    docker.io \
    git \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies with proper native compilation
RUN npm ci

# Copy application files (excluding node_modules)
COPY . .

# Create workspace directory
RUN mkdir -p /tmp/pocketdev-workspaces

# Expose API port
EXPOSE 3001

# Start development server
CMD ["npm", "run", "dev"]