# Secure Shelltender service built on AI base
FROM pocketdev/ai-base:latest

# Switch to root for final setup
USER root

# Install gosu if not already present (AI base might not have it)
RUN which gosu || (apt-get update && apt-get install -y gosu && rm -rf /var/lib/apt/lists/*)

# Copy secure entrypoint
COPY docker-entrypoint-secure.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Copy Shelltender wrapper scripts
COPY <<'EOF' /usr/local/bin/shelltender-pty-wrapper.sh
#!/bin/bash
# Wrapper script for Shelltender PTY mode
# This handles proper signal forwarding and cleanup

trap 'kill -TERM $PID' TERM INT

# Start the shelltender process
"$@" &
PID=$!
wait $PID
exit $?
EOF

RUN chmod +x /usr/local/bin/shelltender-pty-wrapper.sh

# Create necessary directories
RUN mkdir -p /app/server /app/data/shelltender-sessions /projects

# Set up wrapper for reading secrets from files
COPY <<'EOF' /usr/local/bin/read-secret.sh
#!/bin/bash
# Read secret from file if *_FILE env var is set
# Usage: eval $(read-secret.sh ANTHROPIC_API_KEY)

VAR_NAME=$1
FILE_VAR="${VAR_NAME}_FILE"

if [ -n "${!FILE_VAR}" ] && [ -f "${!FILE_VAR}" ]; then
    echo "export $VAR_NAME='$(cat ${!FILE_VAR})'"
else
    echo "# No secret file for $VAR_NAME"
fi
EOF
RUN chmod +x /usr/local/bin/read-secret.sh

# Expose Shelltender port
EXPOSE 8080

# Create startup script that loads secrets
COPY <<'EOF' /usr/local/bin/start-shelltender.sh
#!/bin/bash
# Load secrets from files
eval $(read-secret.sh ANTHROPIC_API_KEY)
eval $(read-secret.sh OPENAI_API_KEY)
eval $(read-secret.sh GITHUB_TOKEN)

# Start shelltender
exec node server/shelltender-unified.js
EOF
RUN chmod +x /usr/local/bin/start-shelltender.sh

# Override entrypoint to use secure version
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]

# Default command
CMD ["/usr/local/bin/start-shelltender.sh"]