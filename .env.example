# Copy this to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional
CLAUDE_MODE=container
PORT=3001

# Encryption key for sensitive data (GitHub tokens, etc. stored in database)
# Generate a secure key with: openssl rand -hex 32
# If not set, a default development key will be used (NOT secure for production)
ENCRYPTION_KEY=

# Supabase (optional - uses mock data if not provided)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_service_key